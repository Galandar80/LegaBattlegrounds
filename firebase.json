{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "database_setup/**",
      "__tests__/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
